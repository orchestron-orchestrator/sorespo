            }
            enum vxlan {
              description "VXLAN";
            }
            enum l2-license {
              description "L2 license trace";
            }
            enum telemetry {
              description "Telemetry";
            }
            enum network-isolation {
              description "Network isolation detection";
            }
            enum all {
              description "All operations";
            }
          }
        }
      }
      container kernel {
