              type empty;
            }
            leaf pdu-size {
              description "BFD transport protocol payload size";
              default "24";
              type union {
                type string {
                  pattern "<.*>|$.*";
                }
                type uint32 {
                  range "24 .. 9000";
                }
              }
            }
