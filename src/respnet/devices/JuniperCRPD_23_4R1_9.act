        type enumeration {
          enum 0 {
            description "BFD version 0 (deprecated)";
          }
          enum 1 {
            description "BFD version 1";
          }
          enum automatic {
            description "Choose BFD version automatically";
          }
        }
      }
      leaf minimum-interval {
        description "Minimum transmit and receive interval";
        units milliseconds;
        type union {
          type string {
            pattern "<.*>|$.*";
          }
          type uint32 {
            range "1 .. 255000";
          }
        }
      }
