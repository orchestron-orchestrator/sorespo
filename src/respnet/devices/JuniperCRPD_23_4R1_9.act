                pattern "<.*>|$.*";
              }
              type uint32 {
                range "1 .. 65535";
              }
            }
          }
        }
        leaf maximum {
          description "Maximum limit above which additional entries are not accepted";
          type union {
            type string {
              pattern "<.*>|$.*";
            }
            type uint32 {
              range "1 .. 65535";
            }
          }
        }
        leaf threshold {
          description "Percentage of maximum at which to start generating warnings";
          type union {
            type string {
              pattern "<.*>|$.*";
            }
            type uint32 {
              range "1 .. 100";
            }
          }
        }
        leaf log-interval {
          description "Time between successive log messages";
          type union {
            type string {
              pattern "<.*>|$.*";
            }
            type uint32 {
              range "1 .. 65535";
            }
          }
        }
