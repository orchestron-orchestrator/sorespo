            }
            container unprotected {
              description "Adjacency SID uneligible for protection";
              choice adjsid-type {
                case case_1 {
                  container index {
                    description "Adjacency SID indexed from SRGB";
                    leaf index-number {
                      type union {
                        type string {
                          pattern "<.*>|$.*";
                        }
                        type uint32 {
                          range "0 .. 199999";
                        }
                      }
                    }
                  }
                }
                case case_2 {
                  leaf label {
                    description "Adjacency SID from static label pool";
                    type union {
                      type string {
                        pattern "<.*>|$.*";
                      }
                      type uint32 {
                        range "16 .. 1048575";
                      }
                    }
                  }
                }
                case case_3 {
                  leaf dynamic {
                    description "Dynamically allocate an adjacency segment";
                    type empty;
                  }
                }
              }
            }
