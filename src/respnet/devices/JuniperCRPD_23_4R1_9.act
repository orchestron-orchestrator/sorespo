            pattern "<.*>|$.*";
          }
          type uint32 {
            range "80 .. 100";
          }
        }
      }
      leaf vdsl2-bytes {
        description "Set VDSL2 byte adjust value";
        status deprecated;
        default "0";
        units bytes;
        type union {
          type string {
            pattern "<.*>|$.*";
          }
          type int32 {
            range "-100 .. 100";
          }
        }
      }
