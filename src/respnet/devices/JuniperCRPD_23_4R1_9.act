        units milliseconds;
        type union {
          type string {
            pattern "<.*>|$.*";
          }
          type uint32 {
            range "1 .. 255000";
          }
        }
      }
      leaf minimum-receive-interval {
        description "Minimum receive interval";
        units milliseconds;
        type union {
          type string {
            pattern "<.*>|$.*";
          }
          type uint32 {
            range "1 .. 255000";
          }
        }
