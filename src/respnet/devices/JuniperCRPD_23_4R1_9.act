                  type union {
                    type string {
                      pattern "<.*>|$.*";
                    }
                    type uint32 {
                      range "16 .. 1048575";
                    }
                  }
                }
              }
              case case_3 {
                leaf dynamic {
                  description "Dynamically allocate an adjacency segment";
                  type empty;
                }
              }
            }
          }
        }
