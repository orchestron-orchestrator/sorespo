            type empty;
          }
          leaf ngen-mvpn {
            status deprecated;
            type empty;
          }
          container autodiscovery {
            description "PE router autodiscovery options for SSM MDTs";
            leaf inet-mdt {
              description "MDT-SAFI PE autodiscovery for SSM MDTs";
              type empty;
            }
          }
          leaf disable {
            description "Disable family IPv6";
            type empty;
          }
        }
