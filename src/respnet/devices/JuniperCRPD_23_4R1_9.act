    }
    choice router-type {
      case case_1 {
        leaf egress {
          description "All LSPs for which this router is egress";
          type empty;
        }
      }
      case case_2 {
        leaf ingress {
          description "All LSPs for which this router is ingress";
          type empty;
        }
      }
      case case_3 {
        leaf transit {
          description "All LSPs for which this router is transit";
          type empty;
        }
      }
