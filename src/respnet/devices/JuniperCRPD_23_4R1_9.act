          type union {
            type string {
              pattern "<.*>|$.*";
            }
            type uint32 {
              range "1 .. 255000";
            }
          }
        }
        leaf threshold {
          description "High transmit interval triggering a trap";
          units milliseconds;
          type union {
            type uint32;
            type string {
              pattern "<.*>|$.*";
            }
          }
        }
      }
      container detection-time {
        description "Detection-time options";
        leaf threshold {
          description "High detection-time triggering a trap";
          units milliseconds;
          type union {
            type uint32;
            type string {
              pattern "<.*>|$.*";
            }
          }
        }
