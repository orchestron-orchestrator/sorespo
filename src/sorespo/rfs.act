import yang.adata
import orchestron.device as odev
import orchestron.ttt
from orchestron import UnsupportedDevice

from rtrsecrets.junos import *

import sorespo.layers.base_2 as base

from sorespo.layers.y_2 import orchestron_rfs__rfs__backbone_interface_entry
from sorespo.layers.y_2 import orchestron_rfs__rfs__backbone_interface__dynstate

import sorespo.devices.JuniperCRPD_23_4R1_9 as crpd23

CRPD = True


class BaseConfig(base.BaseConfig):
    def transform(self, i, di):
        if "http://xml.juniper.net/netconf/junos/1.0" in di.modules or "junos-conf-root" in di.modules:
            print("RFS /rfs{{{di.name}}}/base-config transform for JUNOS", err=True)
            dev = crpd23.root()
            dev.configuration.system.host_name = di.name

            # Enable rfc-compliant mode
            services = dev.configuration.system.create_services()
            services.netconf.rfc_compliant = True
            services.netconf.yang_compliant = True

            # HIHIHIHIHIHIHIHIHIHIHIHIHIHIHIHIHI

            return dev
            
        raise UnsupportedDevice()


actor BBInterfaceTransform(update_dynstate: proc(?orchestron_rfs__rfs__backbone_interface__dynstate) -> None, dev: odev.DeviceMgr):

    def on_conf(conf: orchestron_rfs__rfs__backbone_interface_entry):
        print("BBInterfaceTransform.on_conf:{conf.name}")
    print("BBInterfaceTransform started")

class BBInterface(base.BBInterface):
    def transform(self, i, di, dynstate):
        print("RFS /rfs{{{di.name}}}/backbone-interface transform running [{i.name}] <-> {i.remote.device} [{i.remote.interface}]", err=True)

        if "http://xml.juniper.net/netconf/junos/1.0" in di.modules or "junos-conf-root" in di.modules:
            print("RFS /rfs{{{di.name}}}/backbone-interface transform running [{i.name}] <-> {i.remote.device} [{i.remote.interface}] for JUNOS", err=True)
            dev = crpd23.root()
            return dev

        raise UnsupportedDevice()


