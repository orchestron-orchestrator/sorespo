DMust(condition="../../srl_nokia-netinst:type != 'srl_nokia-netinst:host'", description=None, error_app_tag=None, error_message='BGP not supported with network-instance of type host', reference=None)
    ], presence=True, children=[SRC_DNODE_CHILD_13, SRC_DNODE_CHILD_14, SRC_DNODE_CHILD_15, SRC_DNODE_CHILD_16, SRC_DNODE_CHILD_17, SRC_DNODE_CHILD_18])

