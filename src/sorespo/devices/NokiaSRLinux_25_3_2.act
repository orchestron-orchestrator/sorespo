SRC_DNODE_CHILD_1 = DList(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='interface', key=['name'], config=True, description='The list of named interfaces on the device', min_elements=0, ordered_by='system', children=[
    DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='name', config=True, description='The name of the interface\n\nValid options are:\nirb<N>, N=0..255\nlif-<lif_name>\nenp<bus>s<dev>f<fn>, bus=0..255, dev=0..31, fn=0..7\nvhn-<vhn_name>\nlag<N>, N=1..1000 [note1]\nlo<N>, N=0..255\nmgmt0\nmgmt0-standby\nethernet-<slot>/<port>\nethernet-<slot>/<connector>/<port>\nethernet-<slot>/m<mda>/<port>\nethernet-<slot>/m<mda>/<connector>/<port>\nsystem0\nsync0\n\n<lif_name>=Linux interface name\n<vhn_name>=vhost interface name\n<slot>=slot number {{1,2,3,..}}\n<mda>=mda id {{1,2,3,..}}\n<connector>=connector id {{1,2,3,..}}\n<port>=port id {{1,2,3,..}}\n\n[note1] The maximum number of LAGs per platform is as follows:\n D1: 32 (N must be 1..32)\n D2-D3: 128 (N must be 1..1000)\n D4-D5: 64 (N must be 1..64)\n H2-H3: 127 (N must be 1..127)\n H4-32D: 127 (N must be 1..127)\n H4: 255 (N must be 1..255)\n IXR: 128 (N must be 1..128)\n SXR-1d-32D: 128 (N must be 1..128)\n SXR-1x-44S: 128 (N must be 1..128)\n vSRL: 8 (N must be 1..8)\n A1: 10 (N must be 1..10)\n IXR-X1b: 512 (N must be 1..512)\n IXR-X3b: 512 (N must be 1..512)', mandatory=False, type_=DTypeString(name='srl_nokia-comm:interface-all', description=None, reference=None, exts=[], builtin_type='string', default=None, length=Ranges([(3, 21)]), patterns=[YangPattern(yang_regex='(mgmt0|mgmt0-standby|system0|sync0|lo(0|1[0-9][0-9]|2([0-4][0-9]|5[0-5])|[1-9][0-9]|[1-9])|lif-.*|vhn-.*|enp(0|1[0-9][0-9]|2([0-4][0-9]|5[0-5])|[1-9][0-9]|[1-9])s(0|[1-9]|[1-2][0-9]|3[0-1])f[0-7]|ethernet-([1-9](\\d){{0,1}}(/m[1-6])?(/[1-9](\\d){{0,1}})?/(([1-9](\\d){{0,1}})|(1[0-1]\\d)|(12[0-8])))|irb(0|1[0-9][0-9]|2([0-4][0-9]|5[0-5])|[1-9][0-9]|[1-9])|lag(([1-9](\\d){{0,2}})|(1000)))', pcre='^((mgmt0|mgmt0-standby|system0|sync0|lo(0|1[0-9][0-9]|2([0-4][0-9]|5[0-5])|[1-9][0-9]|[1-9])|lif-.*|vhn-.*|enp(0|1[0-9][0-9]|2([0-4][0-9]|5[0-5])|[1-9][0-9]|[1-9])s(0|[1-9]|[1-2][0-9]|3[0-1])f[0-7]|ethernet-([1-9](\\p{{Nd}}){{0,1}}(/m[1-6])?(/[1-9](\\p{{Nd}}){{0,1}})?/(([1-9](\\p{{Nd}}){{0,1}})|(1[0-1]\\p{{Nd}})|(12[0-8])))|irb(0|1[0-9][0-9]|2([0-4][0-9]|5[0-5])|[1-9][0-9]|[1-9])|lag(([1-9](\\p{{Nd}}){{0,2}})|(1000))))$', invert=False)])),
    DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='description', config=True, description='A user-configured description of the interface', mandatory=False, reference='RFC 2863: The Interfaces Group MIB - ifAlias', type_=DTypeString(name='srl_nokia-comm:description', description='A user provided description string', reference=None, exts=[], builtin_type='string', default=None, length=Ranges([(1, 255)]), patterns=[])),
    DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='admin-state', config=True, description='The configured, desired state of the interface', default='enable', mandatory=False, must=[
DMust(condition="((. = 'enable') and starts-with(../srl_nokia-if:name, 'system0')) or not(starts-with(../srl_nokia-if:name, 'system0'))", description=None, error_app_tag=None, error_message='admin-state must be enable', reference=None)
        ], reference='RFC 2863: The Interfaces Group MIB - ifAdminStatus', type_=DTypeEnum(name='srl_nokia-comm:admin-state', description='general admin-state option.', reference=None, exts=[], builtin_type='enumeration', default=None, name_to_val={'enable':1, 'disable':2}), exts=[
            DExt(module='srl_nokia-extensions', namespace='urn:nokia.com:srlinux:general:extensions', prefix='srl_nokia-ext', name='show-importance', arg='high', exts=[])
        ]),
    DList(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='subinterface', key=['index'], config=True, description='The list of subinterfaces (logical interfaces) associated with a physical interface', max_elements=4095, min_elements=0, ordered_by='system', children=[
        DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='index', config=True, description='The index of the subinterface, or logical interface number', mandatory=False, must=[
DMust(condition="((. = 0) and starts-with(../../srl_nokia-if:name, 'system0')) or not(starts-with(../../srl_nokia-if:name, 'system0'))", description=None, error_app_tag=None, error_message='subinterface index must be 0 for system0 interface', reference=None),
DMust(condition="not(starts-with(../../srl_nokia-if:name, 'sync0'))", description=None, error_app_tag=None, error_message='subinterfaces not supported on sync0 port', reference=None)
            ], type_=DTypeIntegerUnsigned(name='uint32', description=None, reference=None, exts=[], builtin_type='uint32', default=None, ranges=Ranges([(0, 9999)]))),
        DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='description', config=True, description='A user-configured description of the interface', mandatory=False, reference='RFC 2863: The Interfaces Group MIB - ifAlias', type_=DTypeString(name='srl_nokia-comm:description', description='A user provided description string', reference=None, exts=[], builtin_type='string', default=None, length=Ranges([(1, 255)]), patterns=[])),
        DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='admin-state', config=True, description='The configured, desired state of the subinterface', default='enable', mandatory=False, must=[
DMust(condition="((. = 'enable') and starts-with(../../srl_nokia-if:name, 'system0')) or not(starts-with(../../srl_nokia-if:name, 'system0'))", description=None, error_app_tag=None, error_message='admin-state must be enable', reference=None)
            ], reference='RFC 2863: The Interfaces Group MIB - ifAdminStatus', type_=DTypeEnum(name='srl_nokia-comm:admin-state', description='general admin-state option.', reference=None, exts=[], builtin_type='enumeration', default=None, name_to_val={'enable':1, 'disable':2}), exts=[
                DExt(module='srl_nokia-extensions', namespace='urn:nokia.com:srlinux:general:extensions', prefix='srl_nokia-ext', name='show-importance', arg='high', exts=[])
            ]),
        DContainer(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='ipv4', config=True, description='IPv4 configuration and state for the subinterface', presence=False, children=[
            DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='admin-state', config=True, description='Enable/disable IPv4 on the subinterface\n\nWhen set to enable, and even before an IPv4 address is configured, the subinterface starts to accept incoming packets with dest-ip 255.255.255.255, which is necessary to support dhcp-client functionality.', default='disable', mandatory=False, must=[
DMust(condition="(. = 'disable' or (../../type != 'bridged' and ../../type != 'local-mirror-dest'))", description=None, error_app_tag=None, error_message='ipv4 configuration not allowed on bridged or local-mirror-dest subinterfaces', reference=None)
                ], type_=DTypeEnum(name='srl_nokia-comm:admin-state', description='general admin-state option.', reference=None, exts=[], builtin_type='enumeration', default=None, name_to_val={'enable':1, 'disable':2})),
            DList(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='address', key=['ip-prefix'], config=True, description='The list of  IPv4 addresses assigned to the subinterface.', max_elements=64, min_elements=0, ordered_by='system', children=[
                DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='ip-prefix', config=True, description='The IPv4 address and prefix length in CIDR notation\n\nSubnets on the same subinterface are allowed to overlap as long as the host bits are different. When a locally originated unicast packet is destined to a host covered by multiple subnets associated with a subinterface, the source address is chosen to be the numerically lowest IP address among all these subnets. For example, if the addresses 172.16.1.1/12, 172.16.1.2/12, and 172.16.1.3/12 are configured on the same interface, 172.16.1.1 would be used as a local address when you issue a ping 172.16.1.5 command', mandatory=False, must=[
DMust(condition="not(starts-with(.,'0.') or starts-with(.,'127.') or re-match(.,'22[4-9]\\..*') or re-match(.,'2[3-5][0-9]\\..*'))", description=None, error_app_tag=None, error_message='Not a valid IPv4 unicast address prefix', reference=None),
DMust(condition="(../../unnumbered/admin-state != 'enable')", description=None, error_app_tag=None, error_message='Assignment of IPv4 addresses is prohibited when the subinterface is unnumbered', reference=None)
                    ], type_=DTypeString(name='srl_nokia-comm:ipv4-prefix-with-host-bits', description='An IPv4 prefix with host bits.', reference=None, exts=[], builtin_type='string', default=None, length=None, patterns=[YangPattern(yang_regex='(([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])\\.){{3}}([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])/(([0-9])|([1-2][0-9])|(3[0-2]))', pcre='^((([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])\\.){{3}}([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])/(([0-9])|([1-2][0-9])|(3[0-2])))$', invert=False)]))
            ])
        ]),
        DContainer(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='ipv6', config=True, description='IPv6 configuration and state for the subinterface', presence=False, children=[
            DLeaf(module='srl_nokia-interfaces', namespace='urn:nokia.com:srlinux:chassis:interfaces', prefix='srl_nokia-if', name='admin-state', config=True, description='Enable/disable IPv6 on the subinterface\n\nWhen set to enable, and even before a global unicast IPv6 address is configured, chassis manager assigns an IPv6 link-local address to the subinterface, which will appear as a read-only entry in the address list. At this stage, the subinterface can receive IPv6 packets with any of the following destinations:\n-\tIPv6 link-local address\n-\tsolicited-node multicast address for the link-local address\n-\tff02::1 (all IPv6 devices)\n-\tff02::2 (all IPv6 routers)', default='disable', mandatory=False, must=[
DMust(condition="(. = 'disable' or (../../type != 'bridged' and ../../type != 'local-mirror-dest'))", description=None, error_app_tag=None, error_message='ipv6 configuration not allowed on bridged or local-mirror-dest subinterfaces', reference=None)
                ], type_=DTypeEnum(name='srl_nokia-comm:admin-state', description='general admin-state option.', reference=None, exts=[], builtin_type='enumeration', default=None, name_to_val={'enable':1, 'disable':2}))
        ]),
        DContainer(module='srl_nokia-interfaces-vlans', namespace='urn:nokia.com:srlinux:chassis:interfaces-vlans', prefix='srl_nokia-if-vlan', name='vlan', config=True, description='Parameters for VLAN definition under SRL interfaces', presence=False, children=[
            DContainer(module='srl_nokia-interfaces-vlans', namespace='urn:nokia.com:srlinux:chassis:interfaces-vlans', prefix='srl_nokia-if-vlan', name='encap', config=True, description='VLAN match parmeters for the associated subinterface', presence=False, children=[
                DContainer(module='srl_nokia-interfaces-vlans', namespace='urn:nokia.com:srlinux:chassis:interfaces-vlans', prefix='srl_nokia-if-vlan', name='single-tagged', config=True, description='When present, tagged frames with a specific, non-zero, outer VLAN ID are associated to the subinterface\n\nThe outer VLAN-ID tag is considered service delimiting and it is by default stripped at ingress and restored/added on egress.', presence=True, children=[
                    DLeaf(module='srl_nokia-interfaces-vlans', namespace='urn:nokia.com:srlinux:chassis:interfaces-vlans', prefix='srl_nokia-if-vlan', name='vlan-id', config=True, description='VLAN identifier for single-tagged packets', mandatory=False, must=[
DMust(condition='(../../../../../vlan-tagging = true())', description=None, error_app_tag=None, error_message='vlan-id only configurable if vlan-tagging enabled on parent interface', reference=None),
DMust(condition="string(.) != 'optional' or (../../../../srl_nokia-if:type = 'srl_nokia-if:bridged')", description=None, error_app_tag=None, error_message='vlan-id optional only configurable on bridged subinterface', reference=None),
DMust(condition="string(.) != 'any' or (../../../../srl_nokia-if:type = 'srl_nokia-if:bridged')", description=None, error_app_tag=None, error_message='vlan-id any only configurable on bridged subinterface', reference=None)
                        ], type_=DTypeUnion(name='union', description=None, reference=None, exts=[], builtin_type='union', default=None, types=[DTypeIntegerUnsigned(name='vlan-id', description='Type definition representing a single-tagged VLAN', reference=None, exts=[], builtin_type='uint16', default=None, ranges=Ranges([(1, 4094)])), DTypeEnum(name='enumeration', description=None, reference=None, exts=[], builtin_type='enumeration', default=None, name_to_val={'optional':0, 'any':1})]))
                ])
            ])
        ])
    ]),
    DLeaf(module='srl_nokia-interfaces-vlans', namespace='urn:nokia.com:srlinux:chassis:interfaces-vlans', prefix='srl_nokia-if-vlan', name='vlan-tagging', config=True, description='When set to true the interface is allowed to accept frames with one or more VLAN tags', mandatory=False, must=[
DMust(condition="starts-with(../srl_nokia-if:name, 'ethernet') or starts-with(../srl_nokia-if:name, 'lag') or starts-with(../srl_nokia-if:name, 'lif') or starts-with(../srl_nokia-if:name, 'enp') or starts-with(../srl_nokia-if:name, 'vhn')", description=None, error_app_tag=None, error_message='vlan-tagging not configurable on this interface', reference=None),
DMust(condition='not(../srl_nokia-if:breakout-mode)', description=None, error_app_tag=None, error_message='vlan-tagging not configurable when breakout-mode is enabled', reference=None)
