def adata_LJU_CORE_1():
    # Top node: /root
    ad = root()
    
    # Container: /configuration/system
    ad.configuration.system.host_name = 'LJU-CORE-1'
    
    # P-container: /configuration/system/services
    services = ad.configuration.system.create_services()
    
    # Container: /configuration/system/services/netconf
    services.netconf.rfc_compliant = True
    services.netconf.yang_compliant = True

